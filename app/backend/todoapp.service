[Unit]
Description=SecureApp Todo API
After=network.target

[Service]
Type=simple
User=azureuser
WorkingDirectory=/home/azureuser/todoapp
ExecStart=/home/azureuser/todoapp/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target